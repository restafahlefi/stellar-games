# Server Configuration
PORT=5000
NODE_ENV=development

# GitHub Backup Configuration (REQUIRED for Railway deployment)
# Create a private GitHub repository for user data backup
# Generate a Personal Access Token with 'repo' scope: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO_URL=https://github.com/your-username/stellar-games-data.git
GITHUB_BRANCH=main
GITHUB_USERNAME=stellar-games-bot
GITHUB_EMAIL=bot@stellargames.com

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=30d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Admin Configuration (for future admin panel)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$10$your-bcrypt-hashed-password-here

# Database Configuration (untuk future implementation)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=stellar_games
# DB_USER=postgres
# DB_PASSWORD=password
